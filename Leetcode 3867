class Solution {
public:
    long long gcdSum(vector<int>& nums) {
        int n = nums.size();
        vector<int> v;
        int mx = 0;
        for(int i = 0; i < n; i++) {
            mx = max(mx, nums[i]);
            v.push_back(gcd(nums[i], mx));
        }
        sort(v.begin(), v.end());
        long long ans = 0;
        int l = 0, r = n - 1;
        while(l < r) {
            ans += gcd(v[l], v[r]);
            l++;
            r--;
        }
        return ans;
    }
};
