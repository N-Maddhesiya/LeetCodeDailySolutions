class Solution {
public:
    int getCommon(vector<int>& nums1, vector<int>& nums2) {
        vector<int> result;
        set_intersection(
            nums1.begin(), nums1.end(),
            nums2.begin(), nums2.end(),
            back_inserter(result)
        );
        if(result.size()==0)    return -1;
        return result[0];
    }
};
