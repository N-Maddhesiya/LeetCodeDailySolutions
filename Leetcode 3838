class Solution {
public:
    string mapWordWeights(vector<string>& words, vector<int>& weights) {
        string ans;
        for (const string& w : words) {
            long long sum = 0;
            for (char ch : w) {
                sum += weights[ch - 'a'];
            }
            ans.push_back(char('z' - (sum % 26)));
        }
        return ans;
    }
};
