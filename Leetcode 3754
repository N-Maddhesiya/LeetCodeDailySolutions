class Solution {
public:
    long long sumAndMultiply(int n) {
        long long x=0,sum=0,i=0;
        while(n){
            int r=n%10;
            if(r!=0){
                x=(r*(pow(10,i)))+x;
                i++;
                sum+=r;
            }
            n/=10;
        }
        return sum*x;

    }
};
