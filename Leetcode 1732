class Solution {
public:
    int largestAltitude(vector<int>& gain) {
        vector<int>ans={0};
        // ans.push_back(gain[0]);
        int n=gain.size();
        /*for(int i=0;i<n;i++){
            int a=ans[i+1]+gain[i];
            ans.push_back(a);
        }*/
        for (int i = 0; i < n; i++) {
            ans.push_back(ans.back() + gain[i]);
        }
        return *max_element(ans.begin(),ans.end());
    }
};
