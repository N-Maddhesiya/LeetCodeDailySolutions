class Solution {
public:
    bool isGood(vector<int>& nums) {
        int n=nums.size();
        if(n==1)    return false;
        sort(nums.begin(),nums.end());
        for(int i=0;i<n-2;i++){
            if(nums[i]!=i+1)
                return false;
        }
        int i=nums[n-1],j=nums[n-2];
        if(i==n-1){
            if(j==n-1){
                return true;
            }
            return false; 
        }
        return false;
    }
};
